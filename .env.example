# PostgreSQL — run: createdb rapid_recall
DATABASE_URL="postgresql://postgres:password@localhost:5432/rapid_recall"

# Express session — generate with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-random-string"

# Google OAuth (sign-in) — from Google Cloud Console
# Authorized redirect URI: http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# Google Classroom OAuth (teacher import) — same GCP project, same credentials
# Authorized redirect URI: http://localhost:4000/api/classroom/callback
# Required APIs to enable: Google Classroom API
CLASSROOM_REDIRECT_URI="http://localhost:4000/api/classroom/callback"

# URLs
CLIENT_URL="http://localhost:3000"
SERVER_URL="http://localhost:4000"
NODE_ENV="development"

# First admin setup — run: ADMIN_EMAIL=you@school.edu npm run db:seed
# ADMIN_EMAIL=
